{
  "name": "@cnosuke/omnifocus-cli",
  "version": "1.1.1",
  "bin": {
    "of": "./dist/index.mjs"
  },
  "type": "module",
  "scripts": {
    "build": "vp pack && mkdir -p skills/omnifocus-cli/bin && cp dist/index.mjs skills/omnifocus-cli/bin/of && chmod +x skills/omnifocus-cli/bin/of",
    "dev": "vp dev",
    "check": "vp check",
    "fix": "vp check --fix",
    "test": "vp test",
    "test:run": "vp test run",
    "test:integration": "OF_INTEGRATION=1 vp test run tests/integration"
  },
  "devDependencies": {
    "vite-plus": "^0.1"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.2"
}
