  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        cat <<'EOF'
Usage: of tasks today

List tasks due today.

Examples:
  of tasks today
EOF
        return 0
        ;;
      *)
        echo "Error: Unknown argument '$1'" >&2
        echo "Run 'of tasks today --help' for usage." >&2
        return 1
        ;;
    esac
  done

