    case "$1" in
      --help|-h)
        cat <<'EOF'
Usage: of tasks overdue

List all overdue tasks.

Examples:
  of tasks overdue
EOF
        return 0
        ;;
      *)
        echo "Error: Unknown argument '$1'" >&2
        echo "Run 'of tasks overdue --help' for usage." >&2
        return 1
