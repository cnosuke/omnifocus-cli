cmd_tasks() {
  local sub="${1:-}"
  case "$sub" in
    flagged) shift; cmd_tasks_flagged "$@" ;;
    overdue) shift; cmd_tasks_overdue "$@" ;;
    today) shift; cmd_tasks_today "$@" ;;
    --help|-h)
      cat <<'EOF'
Usage: of tasks <subcommand>

Subcommands:
  flagged    List flagged tasks
  overdue    List overdue tasks
  today      List tasks due today

Run 'of tasks <subcommand> --help' for details.
EOF
      ;;
    *)
      echo "Error: Unknown tasks subcommand '${sub:-}'" >&2
      echo "Run 'of tasks --help' for usage." >&2
      return 1
      ;;
  esac
}

# --- main ---

main() {
  local cmd="${1:-}"
  case "$cmd" in
    inbox) shift; cmd_inbox "$@" ;;
    task) shift; cmd_task "$@" ;;
    tasks) shift; cmd_tasks "$@" ;;
    help|--help|-h|"") show_help ;;
    *)
      echo "Error: Unknown command '$cmd'" >&2
      show_help >&2
      exit 1
      ;;
  esac
}

main "$@"
